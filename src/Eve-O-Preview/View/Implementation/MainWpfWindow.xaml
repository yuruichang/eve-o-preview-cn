<Window x:Class="EveOPreview.View.Implementation.MainWpfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EVE-O Preview" Height="430" Width="540" 
        MinWidth="540" MinHeight="430" 
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei"
        Background="#FFF6F8FA"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="MenuListBox" Grid.Column="0" FontSize="14" BorderThickness="0,0,1,0" BorderBrush="#E1E4E8" Background="White" SelectedIndex="0" Padding="0,15,0,0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="15,12"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBoxItem Content="常规设置" Selected="ListBoxItem_Selected"/>
            <ListBoxItem Content="缩略图"/>
            <ListBoxItem Content="缩放"/>
            <ListBoxItem Content="叠加层"/>
            <ListBoxItem Content="活动客户端"/>
            <ListBoxItem Content="关于"/>
        </ListBox>

        <Grid Grid.Column="1" Margin="25,20,20,20">
            <TabControl x:Name="ContentTabControl" SelectedIndex="{Binding ElementName=MenuListBox, Path=SelectedIndex}" Background="Transparent" BorderThickness="0">

                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <TabItem>
                    <StackPanel Margin="5,0,5,5">
                        <TextBlock Text="常规设置" FontSize="22" FontWeight="Bold" Margin="0,0,0,25" Foreground="#24292E"/>

                        <CheckBox x:Name="MinimizeToTrayCheckBox" Content="最小化到系统托盘" FontSize="14" Margin="0,8" Foreground="#333333"/>
                        <CheckBox x:Name="ShowThumbnailsAlwaysOnTopCheckBox" Content="缩略图始终置顶 (总在最前)" FontSize="14" Margin="0,8" Foreground="#333333"/>
                        <CheckBox x:Name="HideThumbnailsOnLostFocusCheckBox" Content="失去焦点时隐藏缩略图" FontSize="14" Margin="0,8" Foreground="#333333"/>
                        <CheckBox x:Name="EnableClientLayoutTrackingCheckBox" Content="开启客户端位置追踪" FontSize="14" Margin="0,8" Foreground="#333333"/>
                        <CheckBox x:Name="HideActiveClientThumbnailCheckBox" Content="隐藏当前活动客户端的缩略图" FontSize="14" Margin="0,8" Foreground="#333333"/>
                        <CheckBox x:Name="MinimizeInactiveClientsCheckBox" Content="自动最小化非活动客户端" FontSize="14" Margin="0,8" Foreground="#333333"/>
                        <CheckBox x:Name="EnablePerClientThumbnailLayoutsCheckBox" Content="为每个客户端保存独立的布局" FontSize="14" Margin="0,8" Foreground="#333333"/>
                    </StackPanel>
                </TabItem>

                <TabItem>
                    <StackPanel Margin="5,0,5,5">
                        <TextBlock Text="缩略图设置" FontSize="22" FontWeight="Bold" Margin="0,0,0,30" Foreground="#24292E"/>

                        <TextBlock Text="缩略图不透明度" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#444444"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,35">
                            <Slider x:Name="OpacitySlider" Minimum="10" Maximum="100" Value="100" Width="220" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ElementName=OpacitySlider, Path=Value, StringFormat={}{0}%}" FontSize="15" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#0366D6"/>
                        </StackPanel>

                        <TextBlock Text="缩略图尺寸 (宽 x 高)" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#444444"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="ThumbWidthText" Width="60" FontSize="14" TextAlignment="Center" Padding="4" BorderBrush="#D1D5DA"/>
                            <TextBlock Text=" ✕ " FontSize="16" Margin="10,0" VerticalAlignment="Center" Foreground="#959DA5"/>
                            <TextBox x:Name="ThumbHeightText" Width="60" FontSize="14" TextAlignment="Center" Padding="4" BorderBrush="#D1D5DA"/>
                            <TextBlock Text="(修改后点击空白处生效)" Foreground="#6A737D" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem>
                    <StackPanel Margin="5,0,5,5">
                        <TextBlock Text="鼠标悬停缩放设置" FontSize="22" FontWeight="Bold" Margin="0,0,0,25" Foreground="#24292E"/>

                        <CheckBox x:Name="EnableThumbnailZoomCheckBox" Content="启用鼠标悬停时放大缩略图" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,20" Foreground="#24292E"/>

                        <StackPanel x:Name="ZoomSettingsPanel" Margin="28,0,0,0" IsEnabled="{Binding ElementName=EnableThumbnailZoomCheckBox, Path=IsChecked}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                <TextBlock Text="放大倍数: " FontSize="14" VerticalAlignment="Center" Foreground="#444444"/>
                                <TextBox x:Name="ZoomFactorText" Width="55" FontSize="14" TextAlignment="Center" Padding="3" BorderBrush="#D1D5DA"/>
                            </StackPanel>

                            <TextBlock Text="放大时的对齐锚点:" FontSize="14" Margin="0,0,0,12" Foreground="#444444"/>
                            <Grid Width="150" HorizontalAlignment="Left">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="RadioNW" Content="↖" FontSize="13" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RadioN"  Content="↑" FontSize="13" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RadioNE" Content="↗" FontSize="13" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RadioW"  Content="←" FontSize="13" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RadioC"  Content="·" FontSize="13" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RadioE"  Content="→" FontSize="13" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RadioSW" Content="↙" FontSize="13" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RadioS"  Content="↓" FontSize="13" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RadioSE" Content="↘" FontSize="13" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem>
                    <StackPanel Margin="5,0,5,5">
                        <TextBlock Text="叠加层与边框设置" FontSize="22" FontWeight="Bold" Margin="0,0,0,25" Foreground="#24292E"/>

                        <CheckBox x:Name="ShowThumbnailOverlaysCheckBox" Content="显示缩略图叠加层 (如角色名字)" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#24292E"/>

                        <StackPanel Margin="28,0,0,25" IsEnabled="{Binding ElementName=ShowThumbnailOverlaysCheckBox, Path=IsChecked}">
                            <TextBlock Text="自定义叠加层字体与颜色:" FontSize="12" Foreground="#6A737D" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ChangeFontButton" Content="修改字体与颜色..." Width="120" Height="26" FontSize="12" Cursor="Hand" Click="ChangeFontButton_Click" Background="#F3F4F6" BorderBrush="#D1D5DA"/>
                                <TextBlock x:Name="FontPreviewText" Text="当前字体: 读取中..." FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#444444"/>
                            </StackPanel>
                        </StackPanel>

                        <Separator Margin="0,0,0,20" Background="#E1E4E8"/>

                        <CheckBox x:Name="ShowThumbnailFramesCheckBox" Content="显示缩略图外部边框" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#24292E"/>

                        <CheckBox x:Name="EnableActiveClientHighlightCheckBox" Content="启用当前活动窗口的高亮边框" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#24292E"/>
                        <StackPanel Orientation="Horizontal" Margin="28,0,0,0" IsEnabled="{Binding ElementName=EnableActiveClientHighlightCheckBox, Path=IsChecked}">
                            <TextBlock Text="高亮边框颜色: " FontSize="13" Foreground="#6A737D" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button x:Name="HighlightColorButton" Width="50" Height="22" BorderBrush="#D1D5DA" BorderThickness="1" Cursor="Hand" ToolTip="点击修改颜色"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem>
                    <Grid Margin="5,0,5,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="活动客户端管理" FontSize="22" FontWeight="Bold" Margin="0,0,0,10" Foreground="#24292E"/>
                        <TextBlock Grid.Row="1" Text="勾选以显示缩略图。选中列表项可在下方为其设置别名。" FontSize="13" Foreground="#6A737D" Margin="0,0,0,12"/>

                        <Border Grid.Row="2" Background="White" BorderBrush="#E1E4E8" BorderThickness="1" CornerRadius="3" Margin="0,0,0,15">
                            <ListBox x:Name="ClientsListBox" BorderThickness="0" Background="Transparent" Padding="4" ItemsSource="{Binding}" SelectionChanged="ClientsListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <CheckBox IsChecked="{Binding IsEnabled}" Content="{Binding Title}" FontSize="14" VerticalAlignment="Center" Click="ClientCheckBox_Click" Foreground="#333333"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <StackPanel Grid.Row="3" x:Name="ClientNotePanel" IsEnabled="False">
                            <TextBlock Text="选中客户端的自定义别名:" FontSize="13" Margin="0,0,0,6" Foreground="#444444"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="ClientNoteText" Width="240" FontSize="14" Padding="4" BorderBrush="#D1D5DA" LostFocus="ClientNoteText_LostFocus"/>
                                <TextBlock Text="(点击空白处保存)" Foreground="#959DA5" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="EVE-O Preview" FontSize="34" FontWeight="Bold" Foreground="#24292E" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock x:Name="VersionTextBlock" Text="版本: 读取中..." FontSize="14" Foreground="#6A737D" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                        <Button x:Name="DocsButton" Content="打开官方Discord" Width="200" Height="34" FontSize="14" Cursor="Hand" Click="DocsButton_Click" Background="#0366D6" Foreground="White" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <TextBlock Text="—— 已注入 WPF 现代化界面引擎 ——" FontSize="12" Foreground="#D1D5DA" HorizontalAlignment="Center" Margin="0,45,0,0"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>