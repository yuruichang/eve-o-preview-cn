<Window x:Class="EveOMock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="http://helix-toolkit.org"
        xmlns:sharpDx="http://helix-toolkit.org/wpf/SharpDX"
        Title="Mock" Height="480" Width="640">
    <Grid x:Name="grid">
        <sharpDx:Viewport3DX x:Name="viewPort" 
                             EnableSwapChainRendering="True" 
                             FXAALevel="None"
                             MSAA="Disable">
            <sharpDx:Viewport3DX.Camera>
                <sharpDx:PerspectiveCamera Position="3, 3, 5" LookDirection="-3, -3, -5" UpDirection="0, 1, 0"/>
            </sharpDx:Viewport3DX.Camera>

            <sharpDx:DirectionalLight3D Color="White" Direction="-1, -1, -1" />
            <sharpDx:MeshGeometryModel3D x:Name="cubeModel" />
        </sharpDx:Viewport3DX>
    </Grid>
</Window>